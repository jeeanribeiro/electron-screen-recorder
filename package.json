{
  "name": "electron-screen-recorder",
  "version": "1.0.0",
  "description": "Small, secure screen recorder for macOS, Windows, and Linux — source picker, mp4 export, auto-updates.",
  "main": "out/main/index.js",
  "author": "Jean Ribeiro <contact@jeanribeiro.dev>",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/jeeanribeiro/electron-screen-recorder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeeanribeiro/electron-screen-recorder.git"
  },
  "bugs": {
    "url": "https://github.com/jeeanribeiro/electron-screen-recorder/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && vue-tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "icons": "node scripts/generate-icons.mjs",
    "screens": "node scripts/capture-screens.mjs",
    "package": "electron-vite build && electron-builder --publish never"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-typescript": "^14.9.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.10.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "vue": "^3.5.40",
    "vue-tsc": "^3.3.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "ffmpeg-static"
    ]
  },
  "keywords": [
    "electron",
    "screen-recorder",
    "desktop-capturer",
    "ffmpeg",
    "vue",
    "vite",
    "typescript"
  ]
}
